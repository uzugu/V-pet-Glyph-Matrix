<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/title_shadow_cyan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMULATOR\n.::. MANUAL"
                android:textAppearance="@style/TextAppearance.Cyber.Title"
                android:textColor="#7700e5ff"
                android:gravity="center"
                android:translationX="2dp"
                android:translationY="2dp" />

            <TextView
                android:id="@+id/title_shadow_pink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMULATOR\n.::. MANUAL"
                android:textAppearance="@style/TextAppearance.Cyber.Title"
                android:textColor="#77ff0055"
                android:gravity="center"
                android:translationX="-2dp"
                android:translationY="-2dp" />

            <TextView
                android:id="@+id/main_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMULATOR\n.::. MANUAL"
                android:textAppearance="@style/TextAppearance.Cyber.Title"
                android:gravity="center" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="USER GUIDE &amp; DATA"
            android:textAppearance="@style/TextAppearance.Cyber.Subtitle"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/cyber_panel_bg"
                android:padding="20dp">

                <!-- ── MODULE 1: CONTROLS ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/cyber_yellow"
                        android:rotation="45"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMULATOR CONTROLS"
                        android:textAppearance="@style/TextAppearance.Cyber.SectionHeader" />
                </LinearLayout>

                <TextView
                    android:id="@+id/text_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="[A] - SELECT / CYCLE\nUsed to move through menus and options.\n\n[B] - CONFIRM / EXECUTE\nUsed to select the highlighted action, feed, train, etc.\n\n[C] - CANCEL / MENU\nUsed to cancel an action or unselect a menu icon.\n\nHIDDEN COMBOS:\n[A] + [B] = Mute Sound Toggle\n[A] + [C] = Reset Device Time\n[B] + [C] = Call Screen Off (Sometimes Wake)"
                    android:textAppearance="@style/TextAppearance.Cyber.Body"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp" />

                <!-- ── MODULE 2: EVOLUTION ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@color/cyber_yellow"
                        android:rotation="45"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="V-PET MECHANICS (V1-V3)"
                        android:textAppearance="@style/TextAppearance.Cyber.SectionHeader" />
                </LinearLayout>

                <TextView
                    android:id="@+id/text_mechanics"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CARE MISTAKES (CM):\nA CM is counted ONLY if you wait 20 minutes (or 60 mins for sleep) after a call AND THEN take care of it. If you completely ignore the call without ever addressing it, it does NOT count as a CM. Ignoring Poop or Injuries also does NOT count as a CM.\n\nTRAINING:\nTraining counts when you successfully play the mini-game and restore Strength (except V1, which counts on start). Overfeeding (feeding until refusal) does not cause CMs but is a specific requirement for some forms.\n\nSLEEP DISTURBANCE:\nWaking the Digimon up by feeding, training, or battling while the lights remain on during its sleep schedule counts as 1 Sleep Disturbance.\n\nPERFECT EVOLUTION (完全体):\nRequires at least 15 battles as a Child and 15 as an Adult. The evolution chance is based ONLY on the Win Rate of your LAST 15 battles in each stage, not your total win rate. E.g., 100% win rate in the last 15 Child battles (+50% chance) and 100% in the last 15 Adult battles (+50% chance) guarantees a Perfect evolution."
                    android:textAppearance="@style/TextAppearance.Cyber.Body"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp" />

                <Button
                    android:id="@+id/btn_back"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="CLOSE MANUAL"
                    android:textColor="@color/cyber_blue"
                    android:textAppearance="@style/TextAppearance.Cyber.Button"
                    android:background="@drawable/cyber_button_bg"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

            <!-- ── Corner brackets (yellow) ── -->
            <View
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="@color/cyber_yellow"
                android:layout_gravity="top|start"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp" />

            <View
                android:layout_width="3dp"
                android:layout_height="24dp"
                android:background="@color/cyber_yellow"
                android:layout_gravity="top|start"
                android:layout_marginTop="10dp"
                android:layout_marginStart="10dp" />

            <View
                android:layout_width="24dp"
                android:layout_height="3dp"
                android:background="@color/cyber_yellow"
                android:layout_gravity="bottom|end"
                android:layout_marginBottom="10dp"
                android:layout_marginEnd="10dp" />

            <View
                android:layout_width="3dp"
                android:layout_height="24dp"
                android:background="@color/cyber_yellow"
                android:layout_gravity="bottom|end"
                android:layout_marginBottom="10dp"
                android:layout_marginEnd="10dp" />
        </FrameLayout>

    </LinearLayout>
</ScrollView>
