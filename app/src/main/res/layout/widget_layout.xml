<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Main display frame — initial src prevents "can't load" before first frame push -->
    <ImageView
        android:id="@+id/widget_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/ic_digimon_preview" />

    <TextView
        android:id="@+id/widget_dnd_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="#AA000000"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:text="DND"
        android:textColor="#F2FF00"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Generic click zones for A / B / C (left / center / right thirds).
         background=selector fills the full zone on press; src removed so no centered icon. -->
    <LinearLayout
        android:id="@+id/zone_columns"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_a"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:src="@drawable/widget_button_selector"
            android:scaleType="fitCenter"
            android:contentDescription="A button" />

        <ImageButton
            android:id="@+id/btn_b"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:src="@drawable/widget_button_selector"
            android:scaleType="fitCenter"
            android:contentDescription="B button" />

        <ImageButton
            android:id="@+id/btn_c"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:src="@drawable/widget_button_selector"
            android:scaleType="fitCenter"
            android:contentDescription="C button" />

    </LinearLayout>

    <!--
        Digivice button hit zones — proportional layout matching DigiviceSkin pixel positions.

        DigiviceSkin renders on a 400×400 bitmap:
          - Device body: left 74% of width
          - Button column: right 26% of width
          - Button centers (Y): 30%, 50%, 70% of height (spacing = bodyH * 0.28)
          - Each button holeRadius = 0.104 × totalWidth  → ~21% tall per button
          - Dead zone top/bottom: ~19% each

        Outer horizontal LinearLayout splits width into 74% body spacer + 26% buttons.
        Inner vertical LinearLayout uses weightSum=100 to place each button zone precisely.
    -->
    <LinearLayout
        android:id="@+id/zone_digivice_buttons"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone">

        <!-- Left spacer: covers body up to button holes (btnCx-holeR = 76.6% of bitmap) -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="77"
            android:background="@android:color/transparent" />

        <!-- Button column: hole diameter = 20.8% of bitmap width -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="21"
            android:orientation="vertical">

            <!-- Top dead zone: ~19% (button A top edge ≈ 19% of total height) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="19"
                android:background="@android:color/transparent" />

            <ImageButton
                android:id="@+id/btn_dv_a"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="21"
                android:background="@android:color/transparent"
                android:src="@drawable/widget_button_selector"
                android:scaleType="fitCenter"
                android:contentDescription="Digivice A button" />

            <ImageButton
                android:id="@+id/btn_dv_b"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="21"
                android:background="@android:color/transparent"
                android:src="@drawable/widget_button_selector"
                android:scaleType="fitCenter"
                android:contentDescription="Digivice B button" />

            <ImageButton
                android:id="@+id/btn_dv_c"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="21"
                android:background="@android:color/transparent"
                android:src="@drawable/widget_button_selector"
                android:scaleType="fitCenter"
                android:contentDescription="Digivice C button" />

            <!-- Bottom dead zone: ~18% (button C bottom edge ≈ 80%) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="18"
                android:background="@android:color/transparent" />

        </LinearLayout>

        <!-- Right dead zone: ~2.6% (button hole right edge ≈ 97.4% of bitmap) -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:background="@android:color/transparent" />

    </LinearLayout>

</FrameLayout>
