<?xml version="1.0" encoding="utf-8"?>
<!-- Icon panel: dark background + cyan grid lines -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="60dp"
    android:height="60dp"
    android:viewportWidth="60"
    android:viewportHeight="60">

    <!-- Dark navy background (slightly different from app bg for depth) -->
    <path
        android:fillColor="#0D1520"
        android:pathData="M0,0 L60,0 L60,60 L0,60 Z" />

    <!-- Horizontal grid lines every 6 units -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#2500E5FF"
        android:strokeWidth="0.5"
        android:pathData="M0,6 L60,6 M0,12 L60,12 M0,18 L60,18 M0,24 L60,24 M0,30 L60,30 M0,36 L60,36 M0,42 L60,42 M0,48 L60,48 M0,54 L60,54" />

    <!-- Vertical grid lines every 6 units -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#2500E5FF"
        android:strokeWidth="0.5"
        android:pathData="M6,0 L6,60 M12,0 L12,60 M18,0 L18,60 M24,0 L24,60 M30,0 L30,60 M36,0 L36,60 M42,0 L42,60 M48,0 L48,60 M54,0 L54,60" />

    <!-- Subtle center glow zone (where icon sits) -->
    <path
        android:fillColor="#10FFD600"
        android:pathData="M12,12 L48,12 L48,48 L12,48 Z" />

</vector>
